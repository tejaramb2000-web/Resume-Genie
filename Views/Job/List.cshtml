@model List<ResumeTailorApp.Models.Job>

@{
    ViewData["Title"] = "Jobs";
}

<style>
    :root {
        --rg-primary: #2563eb;
        --rg-primary-dark: #1d4ed8;
        --rg-text: #0f172a;
        --rg-muted: #64748b;
        --rg-border: #e2e8f0;
        --rg-bg-soft: #f8fafc;
        --rg-card: #ffffff;
        --rg-shadow: 0 20px 40px rgba(15, 23, 42, 0.06);
        --rg-success-bg: #ecfdf3;
        --rg-success-text: #15803d;
    }

    .jobs-page {
        padding: 48px 0 70px;
        background: linear-gradient(to bottom, #ffffff, #f8fbff);
        min-height: calc(100vh - 160px);
    }

    .jobs-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .jobs-header-left h1 {
        font-size: 2.1rem;
        font-weight: 800;
        letter-spacing: -0.8px;
        color: var(--rg-text);
        margin-bottom: 0.6rem;
    }

    .jobs-header-left p {
        color: var(--rg-muted);
        font-size: 1rem;
        margin: 0;
        max-width: 720px;
        line-height: 1.7;
    }

    .jobs-btn-primary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        background: var(--rg-primary);
        color: #fff;
        padding: 0.9rem 1.2rem;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 700;
        border: none;
        box-shadow: 0 14px 28px rgba(37, 99, 235, 0.18);
        white-space: nowrap;
    }

    .jobs-btn-primary:hover {
        background: var(--rg-primary-dark);
        color: #fff;
    }

    .jobs-summary-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .jobs-summary-card {
        background: var(--rg-card);
        border: 1px solid var(--rg-border);
        border-radius: 18px;
        padding: 1.25rem;
        box-shadow: var(--rg-shadow);
    }

    .jobs-summary-label {
        color: var(--rg-muted);
        font-size: 0.92rem;
        font-weight: 600;
        margin-bottom: 0.45rem;
    }

    .jobs-summary-value {
        color: var(--rg-text);
        font-size: 1.75rem;
        font-weight: 800;
        line-height: 1.1;
    }

    .jobs-table-card {
        background: var(--rg-card);
        border: 1px solid var(--rg-border);
        border-radius: 22px;
        box-shadow: var(--rg-shadow);
        overflow: hidden;
    }

    .jobs-table-header {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--rg-border);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .jobs-table-header h2 {
        font-size: 1.15rem;
        font-weight: 700;
        margin: 0;
        color: var(--rg-text);
    }

    .jobs-table-header span {
        color: var(--rg-muted);
        font-size: 0.95rem;
    }

    .jobs-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.4rem 0.7rem;
        border-radius: 999px;
        background: var(--rg-success-bg);
        color: var(--rg-success-text);
        font-size: 0.84rem;
        font-weight: 700;
    }

    .jobs-table-wrap {
        overflow-x: auto;
    }

    .jobs-table {
        width: 100%;
        border-collapse: collapse;
        margin: 0;
    }

    .jobs-table thead th {
        background: #f8fafc;
        color: var(--rg-muted);
        font-size: 0.9rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.4px;
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--rg-border);
    }

    .jobs-table tbody td {
        padding: 1.25rem;
        border-bottom: 1px solid #eef2f7;
        vertical-align: top;
    }

    .jobs-table tbody tr:last-child td {
        border-bottom: none;
    }

    .job-title {
        font-weight: 700;
        color: var(--rg-text);
        margin-bottom: 0.35rem;
        font-size: 1rem;
    }

    .job-subtext {
        color: var(--rg-muted);
        font-size: 0.92rem;
    }

    .job-description-preview {
        color: #334155;
        line-height: 1.7;
        white-space: pre-wrap;
        max-height: 150px;
        overflow: hidden;
        position: relative;
    }

    .job-description-preview::after {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        height: 38px;
        background: linear-gradient(to bottom, rgba(255,255,255,0), #ffffff);
    }

    .empty-state {
        padding: 3rem 1.5rem;
        text-align: center;
    }

    .empty-state h3 {
        font-size: 1.35rem;
        font-weight: 800;
        color: var(--rg-text);
        margin-bottom: 0.75rem;
    }

    .empty-state p {
        color: var(--rg-muted);
        max-width: 560px;
        margin: 0 auto 1.5rem;
        line-height: 1.7;
    }

    @@media (max-width: 991.98px) {
        .jobs-summary-row {
            grid-template-columns: 1fr;
        }

        .jobs-header-left h1 {
            font-size: 1.8rem;
        }
    }

    @@media (max-width: 767.98px) {
        .jobs-page {
            padding: 32px 0 56px;
        }

        .jobs-table thead th,
        .jobs-table tbody td {
            padding: 1rem;
        }
    }
</style>

<section class="jobs-page">
    <div class="container">
        <div class="jobs-header">
            <div class="jobs-header-left">
                <h1>Job Descriptions</h1>
                <p>
                    Save target job descriptions here so you can compare them against your resumes and generate stronger, role-specific versions.
                </p>
            </div>

            <div>
                <a href="/Job/Create" class="jobs-btn-primary">+ Add New Job</a>
            </div>
        </div>

        <div class="jobs-summary-row">
            <div class="jobs-summary-card">
                <div class="jobs-summary-label">Total Jobs</div>
                <div class="jobs-summary-value">@Model.Count</div>
            </div>

            <div class="jobs-summary-card">
                <div class="jobs-summary-label">Ready for Comparison</div>
                <div class="jobs-summary-value">@Model.Count</div>
            </div>

            <div class="jobs-summary-card">
                <div class="jobs-summary-label">Matching Status</div>
                <div class="jobs-summary-value" style="font-size:1.2rem; padding-top:0.25rem;">Active</div>
            </div>
        </div>

        <div class="jobs-table-card">
            <div class="jobs-table-header">
                <div>
                    <h2>Job Library</h2>
                    <span>Keep your saved roles organized and ready for resume tailoring.</span>
                </div>
                <div class="jobs-badge">Role Matching Workspace</div>
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="jobs-table-wrap">
                    <table class="jobs-table">
                        <thead>
                            <tr>
                                <th style="width: 24%;">Title</th>
                                <th>Description Preview</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="job-title">@item.Title</div>
                                        <div class="job-subtext">Saved target role</div>
                                    </td>
                                    <td>
                                        <div class="job-description-preview">@item.Description</div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <h3>No job descriptions added yet</h3>
                    <p>
                        Add your first job description to start comparing role requirements with your resume and generate better tailored versions.
                    </p>
                    <a href="/Job/Create" class="jobs-btn-primary">Add Your First Job</a>
                </div>
            }
        </div>
    </div>
</section>