@model List<ResumeTailorApp.Models.Resume>

@{
    ViewData["Title"] = "Resumes";
}

<section class="resume-page">
    <div class="container">

        <!-- Header -->
        <div class="resume-header">
            <div class="resume-header-left">
                <h1>Your Resumes</h1>
                <p>
                    Manage your base resumes in one place and use them to create tailored versions for different job applications.
                </p>
            </div>

            <a href="/Resume/Create" class="resume-btn-primary">+ Add New Resume</a>
        </div>

        <!-- Summary -->
        <div class="resume-summary-row">
            <div class="resume-summary-card">
                <div class="resume-summary-label">Total Resumes</div>
                <div class="resume-summary-value">@Model.Count</div>
            </div>

            <div class="resume-summary-card">
                <div class="resume-summary-label">Ready for Matching</div>
                <div class="resume-summary-value">@Model.Count</div>
            </div>

            <div class="resume-summary-card">
                <div class="resume-summary-label">Workflow Status</div>
                <div class="resume-summary-value resume-summary-value-small">Active</div>
            </div>
        </div>

        <!-- Table Card -->
        <div class="resume-table-card">

            <div class="resume-table-header">
                <div>
                    <h2>Resume Library</h2>
                    <span>Store, review, and reuse your resume content for job-specific tailoring.</span>
                </div>

                <div class="resume-badge">Professional Resume Workspace</div>
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="resume-table-wrap">
                    <table class="resume-table">
                        <thead>
                            <tr>
                                <th style="width: 22%;">Title</th>
                                <th>Content Preview</th>
                                <th style="width: 18%;">Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                var preview = item.Content ?? "";
                                preview = preview.Replace("\n", " ");

                                if (preview.Length > 160)
                                {
                                    preview = preview.Substring(0, 160) + "...";
                                }

                                <tr onclick="window.location='/Match?resumeId=@item.Id'">
                                    <!-- Title -->
                                    <td>
                                        <div class="resume-title">@item.Title</div>
                                        <div class="resume-subtext">Base resume</div>
                                    </td>

                                    <!-- Preview -->
                                    <td>
                                        <div class="resume-content-preview">
                                            @preview
                                        </div>
                                    </td>

                                    <!-- Actions -->
                                    <td onclick="event.stopPropagation();">
                                        <div class="resume-actions">
                                            <a href="/Match?resumeId=@item.Id" class="resume-action-link resume-action-primary">Match</a>
                                            <span>|</span>
                                            <a href="/Resume/Edit/@item.Id" class="resume-action-link">Edit</a>
                                            <span>|</span>
                                            <a href="/Resume/Delete/@item.Id" class="resume-action-link resume-action-danger">Delete</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>
            }
            else
            {
                <div class="resume-empty-state">
                    <h3>No resumes added yet</h3>
                    <p>
                        Add your first resume to start building tailored versions for different job descriptions and applications.
                    </p>
                    <a href="/Resume/Create" class="resume-btn-primary">Upload Your First Resume</a>
                </div>
            }

        </div>
    </div>
</section>